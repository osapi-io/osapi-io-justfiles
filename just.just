# Justfile formatting recipes for osapi-io projects.

# Reformat justfiles with canonical style
[group('fmt')]
fmt:
    #!/usr/bin/env bash
    set -euo pipefail
    find . \( -name '*.just' -o -iname 'justfile' \) ! -path './.worktrees/*' ! -path './.claude/*' ! -path './.just/*' | while read -r f; do
        just --fmt --unstable --justfile "$f"
    done

# Check justfile formatting
[group('fmt')]
fmt-check:
    #!/usr/bin/env bash
    set -euo pipefail
    failed=0
    while read -r f; do
        if ! just --fmt --check --unstable --justfile "$f" > /dev/null 2>&1; then
            echo "FAIL: $f"
            just --fmt --check --unstable --justfile "$f" 2>&1 || true
            failed=1
        fi
    done < <(find . \( -name '*.just' -o -iname 'justfile' \) ! -path './.worktrees/*' ! -path './.claude/*' ! -path './.just/*')
    exit $failed
